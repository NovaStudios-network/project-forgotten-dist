  "news": [
    {
      "title": "Viewmodel dev mode: live tune position/rotation/scale (F6)",
      "date": "2026-06-24",
      "body": "F6 toggles a viewmodel dev panel. Cycle params with , / . and adjust with [ / ]: PosX, PosY, PosZ, RotX, RotY, RotZ, Scale, with a live HUD read-out. The sprite transform is now fully driven by these params so the held item pose can be dialled in by eye and the numbers baked in afterwards."
    },
    {
      "title": "Add live in-game held-item tuning ([ ] rotate, - = scale) with HUD readout",
      "date": "2026-06-24",
      "body": "Stops the blind guess-and-rebuild loop: the held-item rotation and scale are now adjustable in real time with bracket and minus/equals keys, shown live on the HUD. Reset to an upright starting angle. Once dialled in by eye, the values can be baked as the defaults."
    },
    {
      "title": "Flip held item 180 degrees per feedback",
      "date": "2026-06-24",
      "body": "Rotated the held-tool in-plane orientation a half-turn (55 -> -125) so it sits the right way up."
    },
    {
      "title": "Rotate held item onto the Beta diagonal, pull off the right edge",
      "date": "2026-06-24",
      "body": "Increased in-plane rotation to ~55deg anticlockwise so the tool lies along the diagonal (head up-left, handle in corner) and moved the anchor left so it stops clipping the screen edge."
    },
    {
      "title": "Match held pickaxe pose to Beta reference (stronger diagonal, cornered, larger)",
      "date": "2026-06-24",
      "body": "Increased the in-plane tilt to ~24deg and scale to 0.56, and dropped the anchor into the lower-right corner so the pickaxe lies on a clean 45deg diagonal with the handle in the corner and head toward centre, like the Beta screenshot."
    },
    {
      "title": "Stop held items clipping the bottom-right corner (anchor pulled up/in)",
      "date": "2026-06-24",
      "body": "Moved the viewmodel hand anchor up and slightly inward so torches and narrow items stay fully visible in the lower-right instead of being cut off by the screen edge."
    },
    {
      "title": "Match held-item pose to Beta reference (tilt, scale, corner anchor)",
      "date": "2026-06-24",
      "body": "Flipped the in-plane tilt the correct way, restored scale to 0.5, and anchored the handle in the bottom-right corner so the pickaxe reaches toward centre and the torch leans up-left, matching the Beta screenshots."
    },
    {
      "title": "Tune held-item pose toward Beta (smaller, lower-right, corrected tilt)",
      "date": "2026-06-24",
      "body": "Scaled the 3D held item down (0.62->0.42), pushed the hand anchor into the lower-right corner, and adjusted the in-plane tilt so tools/torches sit like Beta instead of looming large and central. The extrusion pipeline itself is unchanged."
    }
  ],
